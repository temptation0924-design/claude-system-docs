  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"epoch\":%s,\"time\":\"%s\"}' \"$(date +%s)\" \"$(date '+%Y-%m-%d %H:%M KST')\" > ~/.claude/.session_start"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/ref-session-start-remind.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-tracker-init.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/api-key-health-check.sh",
            "timeout": 12
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-start-worklog.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/violation-prevention-inject.sh",
            "timeout": 3
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/drift-detector.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/ref-dispatcher.sh PreToolUse Write",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/ref-dispatcher.sh PreToolUse Bash",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-tracker-log.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "/Users/ihyeon-u/.claude/hooks/debounce_sync.sh"
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Notion__notion-create-pages|mcp__claude_ai_Notion__notion-update-page",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-tracker-log.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Notion__notion-query-database-view",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-tracker-log.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Slack__slack_send_message",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-tracker-log.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-tracker-log.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-tracker-log.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/ref-dispatcher.sh Stop",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-end-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"/Users/ihyeon-u/.claude/hooks/gsd-statusline.js\""
